{
  "name": "engineer-brain-dashboard",
  "version": "1.0.0",
  "description": "Engineer Brain - Azure Support Case Dashboard",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "node --import tsx/esm --watch src/index.ts",
    "dev:web": "cd web && npm run dev",
    "build": "cd web && npm run build",
    "start": "concurrently \"tsx src/index.ts\" \"cd web && npm run dev\"",
    "setup": "powershell -ExecutionPolicy Bypass -File scripts/setup.ps1",
    "test": "vitest run && npm --prefix web test",
    "test:server": "vitest run",
    "test:web": "npm --prefix web test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage && npm --prefix web run test:coverage",
    "postinstall": "cd web && npm install"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.77",
    "@hono/node-server": "^1.13.7",
    "bcryptjs": "^2.4.3",
    "chokidar": "^4.0.3",
    "dotenv": "^17.3.1",
    "hono": "^4.6.14",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.0"
  }
}
